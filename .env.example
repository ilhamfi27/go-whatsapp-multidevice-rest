# -----------------------------------
# Server Configuration
# -----------------------------------
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=3000

# -----------------------------------
# HTTP Configuration
# -----------------------------------
HTTP_BASE_URL=/api/v1/whatsapp

# HTTP_CORS_ORIGIN=*
# HTTP_BODY_LIMIT_SIZE=8m
# HTTP_GZIP_LEVEL=1

# HTTP_CACHE_CAPACITY=100
# HTTP_CACHE_TTL_SECONDS=5

# -----------------------------------
# Authentication Configuration
# -----------------------------------
# AUTH_BASIC_USERNAME=ThisIsUsername
AUTH_BASIC_PASSWORD=ThisIsPassword

AUTH_JWT_SECRET=ThisIsJWTSecret
AUTH_JWT_EXPIRED_HOUR=0

# -----------------------------------
# WhatsApp Configuration
# -----------------------------------
WHATSAPP_DATASTORE_TYPE=sqlite
WHATSAPP_DATASTORE_URI=file:dbs/WhatsApp.db?_pragma=foreign_keys(1)

WHATSAPP_CLIENT_PROXY_URL=""

WHATSAPP_MEDIA_IMAGE_COMPRESSION=true
WHATSAPP_MEDIA_IMAGE_CONVERT_WEBP=true

# WHATSAPP_VERSION_MAJOR=2
# WHATSAPP_VERSION_MINOR=3000
# WHATSAPP_VERSION_PATCH=1019175440

# -----------------------------------
# App Webhook Configuration
# -----------------------------------
APP_WEBHOOK_URL_TARGET=http://localhost:8080/webhook
# APP_WEBHOOK_BASIC_AUTH=

# Comma-separated list of events to forward to the webhook.
# Leave unset or empty to allow all events.
# Available values: message, receipt, chat_presence, presence, group_info, joined_group, picture, connection, call
# APP_WEBHOOK_EVENTS=message,receipt,connection

# Set to true to save every webhook payload as a JSON file for debugging.
# Files are written to WEBHOOK_DEBUG_DIR (default: ./tmp/webhook-debug/).
# WEBHOOK_DEBUG=false
# WEBHOOK_DEBUG_DIR=./tmp/webhook-debug

# -----------------------------------
# Media Storage Configuration
# -----------------------------------
# MEDIA_STORAGE=none
# Options:
#   none  - media is embedded as base64 in the webhook payload (default)
#   local - media is saved to disk and served via GET {HTTP_BASE_URL}/media/{filename}
#   s3    - media is uploaded to any S3-compatible store (AWS, MinIO, Cloudflare R2, etc.)

# --- Local backend ---
# MEDIA_LOCAL_PATH=./media
# MEDIA_LOCAL_BASE_URL=http://localhost:3000/api/v1/whatsapp/media

# --- S3-compatible backend ---
# MEDIA_S3_BUCKET=my-bucket
# MEDIA_S3_ACCESS_KEY=my-access-key
# MEDIA_S3_SECRET_KEY=my-secret-key
# MEDIA_S3_REGION=us-east-1

# Custom endpoint — required for non-AWS providers:
#   MinIO:             MEDIA_S3_ENDPOINT=http://minio:9000
#   Cloudflare R2:     MEDIA_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   DigitalOcean Spaces: MEDIA_S3_ENDPOINT=https://<region>.digitaloceanspaces.com
#   Backblaze B2:      MEDIA_S3_ENDPOINT=https://s3.<region>.backblazeb2.com
# MEDIA_S3_ENDPOINT=

# Set to true for providers that require path-style access (e.g. MinIO)
# MEDIA_S3_PATH_STYLE=false

# Optional key prefix for stored objects, e.g. "whatsapp-media/"
# MEDIA_S3_KEY_PREFIX=

# Optional: override the public base URL used in media_url (e.g. CDN or MinIO public URL)
# MEDIA_S3_PUBLIC_URL=

# -----------------------------------
# 3rd Party Configuration
# -----------------------------------
LIBWEBP_VERSION=0.6.1
